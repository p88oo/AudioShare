name: 编译 AudioShare (适配 Android 16)

on:
  push:
    branches: [ master ]
  workflow_dispatch: # 允许手动点击运行

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: 拉取代码
        uses: actions/checkout@v4

      - name: 设置 JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
          cache: gradle

      - name: 赋予 Gradle 执行权限
        run: chmod +x gradlew

      - name: 编译 APK (Release 版)
        run: ./gradlew assembleRelease --no-build-cache --no-daemon

      - name: 上传 APK 到产物
        uses: actions/upload-artifact@v4
        with:
          name: AudioShare-Android16-适配版
          path: app/build/outputs/apk/release/*.apk
